#!/usr/bin/env python3
"""
bin/mail — TUZHAN Agent Mail v3 客户端唯一入口

职责：
  1. 把 Skill 根目录（本文件的父目录的父目录）加入 sys.path，让 `lib` 可 import。
  2. 检测 requirements.txt 里的依赖缺失 → 自动 `pip install --user` 一次（H5）。
  3. 委托给 lib.cli:main() 解析 argparse + dispatch 到各子命令。

所有业务逻辑都在 lib/ 下，本文件保持 ≤ 60 行。
"""
from __future__ import annotations

import os
import sys
from pathlib import Path

SKILL_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SKILL_ROOT))


def _bootstrap_deps() -> None:
    """首次启动时按 requirements.txt 安装缺失依赖（幂等，通过 data/.installed.flag 短路）"""
    flag = SKILL_ROOT / "data" / ".installed.flag"
    if flag.exists():
        return
    # 真正的 bootstrap 实现见 lib/init.py，此处避免在 skeleton 阶段静默失败
    # P0-3 会把 autofix 逻辑搬到 lib/init.py 里，这里只负责短路
    return


def main() -> int:
    _bootstrap_deps()
    try:
        from lib.cli import main as cli_main
    except ImportError as e:
        sys.stderr.write(
            f"[mail:bootstrap] 无法加载 lib.cli：{e}\n"
            f"请检查：\n"
            f"  1. 你在 Skill 根目录下执行（当前 SKILL_ROOT={SKILL_ROOT}）\n"
            f"  2. lib/ 目录完整，未被破坏\n"
            f"  3. Python 版本 ≥ 3.10\n"
        )
        return 2
    return cli_main(sys.argv[1:])


if __name__ == "__main__":
    sys.exit(main())
