# ============================================================
# TUZHAN Agent Mail — v3 客户端 Skill
# 原则：仓库只含"源码 + 文档 + 元数据"，所有运行时数据严禁入库
# ============================================================

# 运行时数据（inbox/outbox/contacts/cache/logs/config.toml 全部在此）
# 这是 v3 架构的核心契约：data/ 永远是本地状态，禁止 commit
data/

# 敏感信息
.env
.env.*
*.key
*.pem

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 虚拟环境
venv/
.venv/
env/
ENV/

# 构建产物（tag 触发 CI 时会在 dist/ 打包 zip）
dist/
build/
*.zip
*.tar.gz

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# 遗留目录（v2.x 老客户端个性化配置，v3 不再使用）
tuzhan_workspace/
